# Database URL (MongoDB Atlas)
DATABASE_URL=mongodb+srv://<user>:<password>@cluster0.your-mongodb-id.mongodb.net/agent_survey?retryWrites=true&w=majority

# JWT Security
SECRET_KEY=generate_a_secure_random_hex_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# AI Configuration (Groq or Gemini)
GROQ_API_KEY=gsk_your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend Configuration
VITE_API_URL=https://your-backend-on-render.onrender.com/
CORS_ORIGINS=https://your-frontend-on-vercel.vercel.app,http://localhost:5173

# Initial Seed Admin (Security: only used if set)
# SEED_ADMIN_EMAIL=admin@kanan.com
# SEED_ADMIN_PASSWORD=change_this_to_something_secure
